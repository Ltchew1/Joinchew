# CHEW — Environment Variables Template
#
# DO NOT put real values in this file. This file is safe to commit to GitHub
# because it contains no real secrets — it's just documentation of what's needed.
#
# In Vercel: go to your Project → Settings → Environment Variables, and add
# each of these with your REAL values there instead. Vercel keeps those secret
# and injects them only into your serverless functions at runtime.

# Your Stripe secret key (starts with sk_live_ for real payments, or sk_test_
# for testing). Find it in Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_replace_this_in_vercel_only

# Price IDs for each session tier. Create these in Stripe Dashboard → Product
# catalog → add a product for each tier, then copy the Price ID (starts with price_).
STRIPE_PRICE_STRATEGY=price_replace_with_97_dollar_price_id
STRIPE_PRICE_GROWTH=price_replace_with_197_dollar_price_id
STRIPE_PRICE_EXECUTIVE=price_replace_with_297_dollar_price_id

# Webhook signing secret. Get this from Stripe Dashboard → Developers →
# Webhooks → your endpoint → Signing secret (starts with whsec_).
STRIPE_WEBHOOK_SECRET=whsec_replace_this_in_vercel_only

# Postgres connection string. From Vercel Postgres or Supabase (both free to
# start) — copy their provided connection string exactly.
DATABASE_URL=postgres://replace_with_real_connection_string

# Resend API key for sending confirmation/reminder emails. Sign up free at
# resend.com, verify your sending domain, then find this under API Keys.
RESEND_API_KEY=re_replace_this_in_vercel_only

# The "from" address emails are sent from. Must be on a domain verified in Resend.
FROM_EMAIL=CHEW <bookings@joinchew.com>

# Optional: lets you manually trigger the reminder cron job for testing via
# /api/send-reminders?manual=<this value>. Pick any random string.
CRON_MANUAL_SECRET=replace_with_any_random_string

# Your live site URL, no trailing slash.
SITE_URL=https://www.joinchew.com

# Anthropic (Claude) API key, used by /api/submit-application.js to score
# admissions applications. Find it at console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=sk-ant-replace_this_in_vercel_only

# Shared secret that gates the admissions review queue (admin-applications.html
# and its two API endpoints) — there's no full login system yet, so this is a
# simple gate: /admin-applications.html?secret=<this value>. Pick any long
# random string.
ADMIN_SECRET=replace_with_any_random_string

# Post-acceptance program entry/recurring pricing. Create each as a Price in
# Stripe Dashboard → Product catalog, then copy its Price ID (starts with
# price_). The remainder balance for Infrastructure/Executive (full fee minus
# entry fee) has no separate Price object — it's charged as a computed
# amount via Stripe's inline price_data instead (see
# api/create-remainder-checkout-session.js). Klarna and Afterpay/Clearpay
# must also be enabled under Settings → Payment methods for the remainder
# checkout to actually offer them.
STRIPE_PRICE_INFRASTRUCTURE_ENTRY=price_replace_with_297_dollar_entry_price_id
STRIPE_PRICE_EXECUTIVE_ENTRY=price_replace_with_597_dollar_entry_price_id
STRIPE_PRICE_MEMBERSHIP_ENTRY=price_replace_with_147_dollar_entry_price_id
STRIPE_PRICE_MEMBERSHIP_RECURRING=price_replace_with_97_dollar_per_month_price_id

# Clerk secret key — same shared Clerk instance/value as chew-portal's own
# CLERK_SECRET_KEY. Used only to create invitation-only sign-up access to the
# client portal at admission decision time (see api/send-decision.js and
# lib/clerk.js). Find it in Clerk Dashboard → API Keys.
CLERK_SECRET_KEY=sk_test_replace_this_in_vercel_only

# The client portal's (chew-portal) live URL, no trailing slash. Used to build
# the redirect_url for portal invitations.
PORTAL_URL=https://chew-portal-gzpr.vercel.app
